generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(uuid())
  email      String?  @unique
  name       String?
  password   String?
  steamId    String?  @unique
  avatar     String?
  profileUrl String?
  tradeUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  inventory  UserInventoryItem[]
  orders     Order[]
  quotes     Quote[]

  listings   SkinListing[]
  purchases  Purchase[]
  trades     Trade[]
  supportTickets OrderTicket[]
  ticketMessages TicketMessage[] @relation("UserTicketMessages")
  notifications  Notification[]
  raffleTickets  RaffleTicket[]
  wonPrizes      RafflePrize[]
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closedTickets OrderTicket[] @relation("ClosedTickets")
  ticketMessages TicketMessage[] @relation("AdminTicketMessages")
  notifications  Notification[]
}

model StoreItem {
  assetId       String   @id
  classId       String
  name          String
  type          String
  iconUrl       String?
  tradable      Boolean  @default(true)
  marketable    Boolean  @default(true)
  botSteamId    String
  price         Float    @default(0.0)
  isPriceManual Boolean  @default(false)
  rarity        String   @default("common")
  exterior      String?
  category      String   @default("other")
  isStatTrak    Boolean  @default(false)
  isSouvenir    Boolean  @default(false)
  float         Float?
  pattern       Int?
  paintIndex    Int?
  inspectLink   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Catálogo de ítems de reventa provenientes de YouPin 
model MarketListing {
  id            String   @id @default(cuid())
  name          String   @unique
  provider      String   // 'youpin' — plataforma de reventa
  youpinAsk     Float?
  youpinVolume  Int?
  price         Float    @default(0.0) // precio base seleccionado (YouPin)
  iconUrl       String?
  rarity        String   @default("common")
  exterior      String?
  category      String   @default("other")
  isStatTrak    Boolean  @default(false)
  isSouvenir    Boolean  @default(false)
  isPriceManual Boolean  @default(false)
  /// Último intento de indexar floats (se setea aunque no se encuentren), para priorizar el reindexado.
  floatsSyncedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  floats        FloatItem[]

  @@index([exterior, floatsSyncedAt])
}

model UserInventoryItem {
  assetId    String   @id
  classId    String
  name       String
  type       String
  iconUrl    String?
  tradable   Boolean  @default(true)
  marketable Boolean  @default(true)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  price      Float    @default(0.0)
  rarity     String   @default("common")
  exterior   String?
  category   String   @default("other")
  isStatTrak Boolean  @default(false)
  isSouvenir Boolean  @default(false)
  float      Float?
  pattern    Int?
  paintIndex Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  TRADE_PENDING
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum TicketSenderType {
  USER
  ADMIN
}

model Order {
  id         String      @id @default(uuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       OrderType
  status     OrderStatus @default(PENDING_PAYMENT)
  totalPrice Float
  paymentMethod String?
  metadata   Json?
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tickets    OrderTicket[]
  botId      String?
  bot        Bot?        @relation(fields: [botId], references: [id], onDelete: SetNull)
  raffleTickets RaffleTicket[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assetId   String
  name      String
  price     Float
  iconUrl   String?
  rarity    String?
  exterior  String?
  float     Float?
  pattern   Int?
  provider  String?
}

model OrderTicket {
  id              String       @id @default(uuid())
  orderId         String
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         String
  status          TicketStatus @default(OPEN)
  userLastReadAt  DateTime?
  adminLastReadAt DateTime?
  closedAt        DateTime?
  closedByAdminId String?
  closedByAdmin   Admin?       @relation("ClosedTickets", fields: [closedByAdminId], references: [id], onDelete: SetNull)
  messages        TicketMessage[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, status, updatedAt])
  @@index([orderId, status])
  @@index([status, updatedAt])
}

model TicketMessage {
  id              String           @id @default(uuid())
  ticketId        String
  ticket          OrderTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType      TicketSenderType
  senderUserId    String?
  senderUser      User?            @relation("UserTicketMessages", fields: [senderUserId], references: [id], onDelete: SetNull)
  senderAdminId   String?
  senderAdmin     Admin?           @relation("AdminTicketMessages", fields: [senderAdminId], references: [id], onDelete: SetNull)
  clientMessageId String
  body            String
  createdAt       DateTime         @default(now())

  @@unique([ticketId, clientMessageId])
  @@index([ticketId, createdAt])
}

model AdminSettings {
  id                         String   @id @default(uuid())

  // Modificador global para ítems físicos de bots
  globalPriceModifierType    String   @default("percentage_increase")
  globalPriceModifierValue   Float    @default(0.0)
  globalPriceModifierEnabled Boolean  @default(false)
  
  // Reglas para cuando el usuario vende
  userSellModifierType       String   @default("percentage_decrease")
  userSellModifierValue      Float    @default(0.0)
  userSellModifierEnabled    Boolean  @default(false)

  // Modificador para market listings (YouPin) — independiente de bots
  marketModifierType         String   @default("percentage_increase")
  marketModifierValue        Float    @default(0.0)
  marketModifierEnabled      Boolean  @default(false)

  minimumUserSellPrice       Float    @default(1.0)
  webhookUrl                 String?
  currency                   String   @default("USD")
  mercadoPagoEnabled         Boolean  @default(true)
  paypalEnabled              Boolean  @default(true)
  nowpaymentsEnabled         Boolean  @default(true)
  manualTransferEnabled      Boolean  @default(false)
  manualBankAlias            String?
  manualBankCbu              String?
  manualBankHolder           String?
  manualBankInstructions     String?
  manualCryptoAddress        String?
  manualCryptoNetwork        String?
  manualCryptoInstructions   String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model EncryptedSetting {
  key              String   @id
  encryptedValue   String
  iv               String
  authTag          String
  last4            String?
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model RuntimeSetting {
  key              String   @id
  value            String
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String?
  action    String
  target    String
  createdAt DateTime @default(now())
}

model Bot {
  id           String   @id @default(uuid())
  name         String
  steamId      String   @unique
  tradeUrl     String?
  status       String   @default("active") // active, inactive, maintenance, full, error
  maxItems     Int      @default(1000)
  currentItems Int      @default(0)
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings     SkinListing[]
  purchases    Purchase[]
  trades       Trade[]
  orders       Order[]
}

model SkinListing {
  id               String   @id @default(uuid())
  userId           String?  // Null if from bot/system, or link to User if selling from inventory
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  botId            String?
  bot              Bot?     @relation(fields: [botId], references: [id], onDelete: SetNull)
  skinId           String   // Reference to assetId (StoreItem or UserInventoryItem)
  basePrice        Float
  finalPrice       Float
  status           String   @default("active") // draft, active, reserved, sold, cancelled, expired
  reservedByUserId String?
  reservedUntil    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchases        Purchase[]
}

model Purchase {
  id             String      @id @default(uuid())
  buyerId        String
  buyer          User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  listingId      String
  listing        SkinListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  skinId         String      // assetId
  botId          String?
  bot            Bot?        @relation(fields: [botId], references: [id], onDelete: SetNull)
  basePrice      Float
  finalPrice     Float
  paymentStatus  String      @default("pending_payment") // pending_payment, paid, failed, refunded
  tradeStatus    String      @default("pending") // pending, sent, accepted, failed, cancelled
  status         String      @default("pending_payment") // pending_payment, paid, trade_pending, trade_sent, trade_accepted, cancelled, failed, refunded
  paidAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  trades         Trade[]
}

model Trade {
  id                String    @id @default(uuid())
  purchaseId        String
  purchase          Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  botId             String
  bot               Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  steamTradeOfferId String?
  status            String    @default("pending") // pending, sent, accepted, failed, cancelled
  errorMessage      String?
  sentAt            DateTime?
  acceptedAt        DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model FloatItem {
  id           String        @id @default(uuid())
  assetId      String
  floatValue   Float
  paintSeed    Int
  market       String        // 'YOUPIN'
  price        Float         // Precio original de mercado en USD
  inspectLink  String?
  available    Boolean       @default(true)
  externalId   String?
  lastSyncAt   DateTime      @default(now())
  
  resaleItemId String
  resaleItem   MarketListing @relation(fields: [resaleItemId], references: [id], onDelete: Cascade)

  @@map("floats")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   // e.g. "TICKET_MESSAGE", "ORDER_STATUS", "SYSTEM"
  read      Boolean  @default(false)
  link      String?  // Frontend redirection path
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, read])
  @@index([adminId, read])
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  CANCELLED
}

model Quote {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    QuoteStatus @default(PENDING)
  items     QuoteItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model QuoteItem {
  id         String   @id @default(uuid())
  quoteId    String
  quote      Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  assetId    String
  name       String
  price      Float?
  iconUrl    String?
  rarity     String?
  exterior   String?
  float      Float?
  pattern    Int?
  paintIndex Int?
}

model Raffle {
  id          String   @id @default(uuid())
  name        String
  description String?
  drawDate    DateTime
  ticketPrice Float
  maxTickets  Int?
  status      String   @default("PENDING") // PENDING, ACTIVE, FINISHED, CANCELLED
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prizes      RafflePrize[]
  tickets     RaffleTicket[]
}

model RafflePrize {
  id          String   @id @default(uuid())
  raffleId    String
  raffle      Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  
  position    Int      @default(1) // Puesto en el sorteo (1er lugar, 2do lugar, etc.)

  assetId     String   // Can be bot assetId or youpin-id
  name        String
  price       Float
  iconUrl     String?
  rarity      String?
  exterior    String?
  float       Float?
  pattern     Int?
  provider    String   // 'bot' or 'youpin'
  
  winnerId    String?
  winner      User?    @relation(fields: [winnerId], references: [id], onDelete: SetNull)
  
  winningTicketId String?
  winningTicket  RaffleTicket? @relation("WinningTicket", fields: [winningTicketId], references: [id], onDelete: SetNull)
}

model RaffleTicket {
  id           String   @id @default(uuid())
  raffleId     String
  raffle       Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ticketNumber Int
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  status       String   @default("PENDING") // PENDING, PAID, CANCELLED
  purchaseDate DateTime @default(now())
  
  wonPrizes    RafflePrize[] @relation("WinningTicket")
}


