generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String?  @unique
  name       String?
  password   String?
  steamId    String?  @unique
  avatar     String?
  profileUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  inventory  UserInventoryItem[]
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreItem {
  assetId    String   @id
  classId    String
  name       String
  type       String
  iconUrl    String?
  tradable   Boolean  @default(true)
  marketable Boolean  @default(true)
  botSteamId String
  price      Float    @default(0.0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model UserInventoryItem {
  assetId    String   @id
  classId    String
  name       String
  type       String
  iconUrl    String?
  tradable   Boolean  @default(true)
  marketable Boolean  @default(true)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  price      Float    @default(0.0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
