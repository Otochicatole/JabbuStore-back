# ═════════════════════════════════════════════════════════════════════════
# ⚙️ CONFIGURACIÓN GENERAL DEL BACKEND — JABBUSTORE
# ═════════════════════════════════════════════════════════════════════════
PORT=8192
JWT_SECRET=tu-secreto-jwt-super-seguro
SESSION_SECRET=tu-secreto-de-session-super-seguro
# Contraseña maestra requerida desde el panel admin para ver/editar/eliminar secretos cifrados.
ADMIN_SECRETS_PASSWORD=una-password-larga-y-unica
# Clave de cifrado AES-256-GCM. Debe ser 32 bytes o base64 de 32 bytes.
# Ejemplo para generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SECRETS_ENCRYPTION_KEY=base64-de-32-bytes
# - NODE_ENV: Entorno de ejecución de la aplicación (development o production).
NODE_ENV=development


# ═════════════════════════════════════════════════════════════════════════
# 🗄️ CONFIGURACIÓN DE LA BASE DE DATOS (Prisma)
# ═════════════════════════════════════════════════════════════════════════
# - DATABASE_URL: SQLite local (archivo fijo en prisma/dev.db).
# - Para producción con PostgreSQL: postgresql://usuario:password@host:5432/jabbustore?schema=public
DATABASE_URL="file:./prisma/dev.db"


# ═════════════════════════════════════════════════════════════════════════
# 🌐 CONFIGURACIÓN DE URLS (Túneles o Redirecciones)
# ═════════════════════════════════════════════════════════════════════════
# - BACKEND_URL: Requerida para que las pasarelas de pago envíen notificaciones IPN (webhooks).
# - FRONTEND_URL: Requerida para redireccionar al usuario tras pagos exitosos o cancelados.
# - En desarrollo local, usa Ngrok o DevTunnels para exponer el backend vía HTTPS público.
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000


# ═════════════════════════════════════════════════════════════════════════
# 🎮 CONFIGURACIÓN DE APIS DE STEAM & INVENTARIOS
# ═════════════════════════════════════════════════════════════════════════
# - STEAM_API_KEY: Obtén tu clave de desarrollador en: https://steamcommunity.com/dev/apikey
# - STEAMWEBAPI_API_KEY: Clave de suscripción premium en https://steamwebapi.com/ para datos de mercado de skins.
STEAM_API_KEY=TU_STEAM_WEB_API_KEY_DE_DESARROLLADOR
STEAMWEBAPI_API_KEY=TU_API_KEY_PREMIUM_DE_STEAMWEBAPI_COM

# Precios bots — fuente principal: Items API con mercado YouPin y USD
# ITEMS_PRICES_ENABLE=false  # desactiva Items API y usa fallback legacy
# ITEMS_PRICES_MARKET=youpin
# ITEMS_PRICES_CURRENCY=USD
# ITEMS_PRICES_CACHE_TTL_MS=300000

# Job 1: catálogo local de precios — GET /steam/api/items guardado como JSON.
# Sólo reemplaza items-catalog.json; no recolecta assets ni sincroniza bots.
ENABLE_ITEMS_CATALOG_SYNC=true
ITEMS_CATALOG_SYNC_INTERVAL_MINUTES=300
# ITEMS_CATALOG_PATH=steamwebapi-json-data/items-catalog.json
# ITEMS_CATALOG_MARKET=youpin
# ITEMS_CATALOG_CURRENCY=USD
# ITEMS_CATALOG_PAGE_SIZE=50000
# ITEMS_CATALOG_MAX_PAGES=10
# ITEMS_CATALOG_STALE_AFTER_MS=86400000

# Legacy/fallback Market Prices — bulk YouPin + Buff al sincronizar
# BOT_PRICE_ENABLE_SECONDARY=false  # desactiva fetch bulk de Buff
# BOT_PRICE_SECONDARY_MARKETS=buff
# YOUPIN_PRICES_CURRENCY=USD
# YOUPIN_PRICES_CACHE_TTL_MS=300000

# - CSFLOAT_API_KEY: Clave de la API de CSFloat para buscar detalles de flotantes y fases de ítems Doppler.
CSFLOAT_API_KEY=tu-api-key-de-csfloat

# Job 2: snapshot atómico de assets del Global Market (cada 5 horas).
# Lee el items-catalog.json vigente para priorizar; no lo descarga ni toca bots.
MARKET_ASSETS_SYNC_INTERVAL_MINUTES=300
# Alias legacy soportado para el intervalo anterior:
# FULL_CATALOG_SYNC_INTERVAL_MINUTES=300
MARKET_ASSETS_TARGET=10000
MARKET_ASSETS_PER_ITEM=10
# Mantiene siempre el máximo de workers para completar la descarga lo antes posible.
# Cambiar a false para volver al escalado/reducción adaptativos.
MARKET_ASSETS_FORCE_MAX_CONCURRENCY=true
# INITIAL_CONCURRENCY sólo se usa cuando FORCE_MAX_CONCURRENCY=false.
MARKET_ASSETS_INITIAL_CONCURRENCY=6
MARKET_ASSETS_CONCURRENCY=48
# SLO de diagnóstico. Al vencer no se publica un snapshot parcial.
MARKET_ASSETS_TARGET_DURATION_SECONDS=600
MARKET_ASSETS_SORT=newest
# La cuota cuenta assets solicitados: una llamada limit=10 reserva 10 unidades.
FLOAT_SYNC_MAX_ASSETS_PER_MINUTE=10000
# Timeout integral de headers + body + parseo; los reintentos se difieren fuera del cliente.
FLOAT_SYNC_REQUEST_TIMEOUT_MS=30000
# Archivos locales atómicos; nunca contienen la API key.
MARKET_ASSETS_CATALOG_PATH=steamwebapi-json-data/market-assets-catalog.json
MARKET_ASSETS_CHECKPOINT_PATH=steamwebapi-json-data/market-assets-checkpoint.json
# Estado durable compartido de la ventana de 10.000 assets/minuto.
FLOAT_SYNC_RATE_LIMIT_STATE_PATH=steamwebapi-json-data/float-rate-limit-state.json

# Fallback legacy sólo para ITEMS_CATALOG_SYNC_INTERVAL_MINUTES.
# El inventario/precio de bots se sincroniza manualmente por su endpoint admin.
STORE_SYNC_INTERVAL_MINUTES=300

# Opciones legacy del sincronizador incremental (no usadas por el job assets-only).
MARKET_SYNC_MIN_PRICE=0
MARKET_SYNC_SORT=newest
# Sync on-demand por skin (modal): sort=lowest_float, limit=FLOAT_SYNC_MAX_PER_ITEM
FLOAT_SYNC_MAX_PER_ITEM=12
FLOAT_SYNC_SORT=lowest_float

# Activar/desactivar únicamente el job periódico de assets del Global Market.
ENABLE_SYNC=true


# ═════════════════════════════════════════════════════════════════════════
# 💳 CONFIGURACIÓN DE MERCADO PAGO — JABBUSTORE
# ═════════════════════════════════════════════════════════════════════════
# - MERCADOPAGO_ACCESS_TOKEN: Token de Acceso (Dashboard de Mercado Pago -> Credenciales).
# - MERCADOPAGO_WEBHOOK_SECRET: Clave firma secreta de webhook de MP (Notificaciones Webhook -> Firma Secreta).
MERCADOPAGO_ACCESS_TOKEN=APP_USR-6583920573920573-060518-xxxxxxxxxxxxxx-123456789
MERCADOPAGO_WEBHOOK_SECRET=tu-firma-secreta-webhook-mercadopago


# ═════════════════════════════════════════════════════════════════════════
# 🪙 CONFIGURACIÓN DE NOWPAYMENTS (Criptomonedas) — JABBUSTORE
# ═════════════════════════════════════════════════════════════════════════
# - NOWPAYMENTS_API_KEY: Obtén tu API Key en tu Dashboard de NOWPayments -> Store settings -> API Keys.
# - NOWPAYMENTS_IPN_SECRET: Firma secreta IPN para verificación HMAC-SHA512 (Dashboard -> Store settings -> IPN Secret).
NOWPAYMENTS_API_KEY=TU_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=TU_NOWPAYMENTS_IPN_SECRET


# ═════════════════════════════════════════════════════════════════════════
# 💵 CONFIGURACIÓN DE PAYPAL — JABBUSTORE
# ═════════════════════════════════════════════════════════════════════════
# - PAYPAL_CLIENT_ID: Identificador de cliente REST de PayPal (Developer Dashboard -> Apps & Credentials).
PAYPAL_CLIENT_ID=TU_PAYPAL_CLIENT_ID
# - PAYPAL_CLIENT_SECRET: Clave secreta REST asociada.
PAYPAL_CLIENT_SECRET=TU_PAYPAL_CLIENT_SECRET
# Alias legacy soportado temporalmente por compatibilidad:
# PAYPAY_CLIENT_ID=TU_PAYPAL_CLIENT_ID
# PAYPAY_CLIENT_SECRET=TU_PAYPAL_CLIENT_SECRET
# - PAYPAL_SANDBOX: "true" para usar el sandbox de pruebas, "false" para usar producción real de PayPal.
PAYPAL_SANDBOX=true
