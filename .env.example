# ═════════════════════════════════════════════════════════════════════════
# 💳 CONFIGURACIÓN DE MERCADO PAGO — JABBUSTORE
# ═════════════════════════════════════════════════════════════════════════

# 1. Tu Token de Acceso (Access Token) de Mercado Pago
# - Para pruebas: Usa tu "Test Access Token" de tus credenciales de prueba.
# - Para producción: Usa tu "Production Access Token" una vez homologado.
# - Consíguelo en: https://developers.mercadopago.com/ panel de tus aplicaciones.
MERCADOPAGO_ACCESS_TOKEN=APP_USR-6583920573920573-060518-6fbf71ff72a56e0d2ab9693cf7c0de82-123456789

# 2. La URL pública de tu Frontend (Next.js)
# - Requerida para redirigir al usuario automáticamente después de pagar.
# - En local/desarrollo: http://localhost:3000
# - En producción: https://tu-tienda.com
FRONTEND_URL=http://localhost:3000

# 3. La URL pública de tu Backend (Express)
# - Requerida para que Mercado Pago pueda golpear tu webhook de acreditación automática de pagos.
# - En producción: https://api.tu-tienda.com
# - En local/desarrollo: Debes usar un túnel público temporal (Ngrok o LocalTunnel) que redireccione a tu puerto 3001.
#   Ejemplo con Ngrok: ngrok http 3001 (copiar la url https de ngrok aquí).
#   Ejemplo: BACKEND_URL=https://abcde-123-45.ngrok-free.app
BACKEND_URL=http://localhost:3001

# 4. Clave Secreta de Verificación de Firma del Webhook de Mercado Pago
# - Opcional pero recomendada para validar criptográficamente que cada webhook es legítimo.
# - Consíguela en: Panel de Developers de Mercado Pago -> Notificaciones Webhook -> Firma Secreta de tu webhook.
MERCADOPAGO_WEBHOOK_SECRET=348617feeb5fbf58ac1ba36e02f7601af33ead4a757ab04283be0fb77d5b67e0


# ═════════════════════════════════════════════════════════════════════════
# 🪙 CONFIGURACIÓN DE NOWPAYMENTS — JABBUSTORE
# ═════════════════════════════════════════════════════════════════════════

# 1. Tu API Key de NOWPayments
# - Consíguela en tu panel de control de NOWPayments (Dashboard -> Store settings -> API Keys).
# - Ejemplo: NOWPAYMENTS_API_KEY=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX
NOWPAYMENTS_API_KEY=TU_NOWPAYMENTS_API_KEY

# 2. Firma Secreta de Notificaciones IPN (Webhook) de NOWPayments
# - Requerida para verificar criptográficamente (HMAC-SHA512) que las notificaciones de pago son legítimas.
# - Consíguela en tu panel de control de NOWPayments (Dashboard -> Store settings -> Instant Payment Notifications -> IPN Secret).
# - Ejemplo: NOWPAYMENTS_IPN_SECRET=xxxxx
NOWPAYMENTS_IPN_SECRET=TU_NOWPAYMENTS_IPN_SECRET


# ⚙️ OTRAS CONFIGURACIONES REQUERIDAS DEL BACKEND
# ═════════════════════════════════════════════════════════════════════════
PORT=3001
DATABASE_URL=postgresql://usuario:password@localhost:5432/jabbustore?schema=public
SESSION_SECRET=secret-super-seguro-para-sesiones-de-bots-y-admins
JWT_SECRET=secret-super-seguro-para-tokens-jwt
STEAM_API_KEY=TU_STEAM_WEB_API_KEY_DE_DESARROLLADOR
STEAMWEBAPI_API_KEY=TU_API_KEY_PREMIUM_DE_STEAMWEBAPI_COM
